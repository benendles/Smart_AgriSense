# Smart AgriSense — environment configuration
# Copy to ".env" and adjust for your VPS.  docker-compose reads this file.

# ── MQTT broker the services publish "capture" commands to ────────────────────
# Inside docker-compose this is the mosquitto service name. The Raspberry Pi,
# which lives on a different network, connects to the broker via the VPS public
# IP (see RASPBERRY_PI_GUIDE.md).
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# ── Public base URL of the deployed API (used by the web app / Pi) ────────────
# e.g. https://api.your-domain.com   or   http://<VPS_PUBLIC_IP>
PUBLIC_API_URL=http://localhost

# ── Advisory service — Claude reasoning over the four models' outputs ─────────
# Get a key at https://console.anthropic.com . Without it the advisory service
# still boots, but /advisory/advise returns "ANTHROPIC_API_KEY not configured".
ANTHROPIC_API_KEY=
ADVISORY_MODEL=claude-opus-4-8

# ── Container image registry (used by Jenkins + k8s) ──────────────────────────
REGISTRY=docker.io/youruser
IMAGE_TAG=latest
