# Smart AgriSense — Environment Variables
# Copy this file to .env.local and fill in your real service URLs.
# Leave a variable empty (or remove it) to use built-in mock data instead.
# Restart the dev server after any change to this file.

# ── Microservice URLs ─────────────────────────────────────────────────────────
# Each variable points to one independent Docker microservice.
# Example — running locally : http://localhost:4001
#           running on VPS  : http://your-vps-ip:4001
#           running on Pi   : http://192.168.x.x:4001

# 1. Sensor Ingestion Service
#    Receives MQTT data from Raspberry Pi and stores time-series readings.
#    Endpoints: GET /sensors/latest  |  GET /sensors/history?hours=24
SENSOR_SERVICE_URL=

# 2. Plant Detection Service
#    Identifies crop type, variety, growth stage from Pi camera images.
#    Endpoints: GET /plant/latest  |  POST /plant/analyze  (multipart image)
PLANT_DETECTION_SERVICE_URL=

# 3. Disease Detection Service
#    Detects plant diseases from leaf images captured by Raspberry Pi.
#    Endpoints: GET /disease/latest  |  POST /disease/analyze  (multipart image)
DISEASE_SERVICE_URL=http://localhost:4005 

# 4. Insect / Pest Detection Service
#    Runs PlantInsectCNN (19 pest classes) on Pi camera images.
#    Endpoints: GET /insect/latest  |  POST /insect/analyze  (multipart image)
INSECT_DETECTION_SERVICE_URL=http://localhost:4004


# 5. Agricultural Practice Service  (the "brain")
#    Aggregates all sensor + detection results and generates farming instructions
#    (irrigate, fertilize, spray, harvest). Sends actuator commands to Pi.
#    Endpoints: GET /agriculture/advice
AGRICULTURE_SERVICE_URL=

# 6. Notification / Alert Service
#    Generates and stores alerts triggered by thresholds and AI detections.
#    Endpoints: GET /alerts
NOTIFICATION_SERVICE_URL=

# ── Raspberry Pi MQTT Topics ──────────────────────────────────────────────────
# The Raspberry Pi publishes sensor readings and camera images over MQTT.
# Your microservices subscribe to these topics and forward data to their APIs.
#
# Pi  →  Broker  →  Microservice  →  Web App
#
# Topic                       Payload (JSON)
# agrisense/sensors           { temperature, humidity, soilMoisture, ph, timestamp }
# agrisense/camera/plant      { imageBase64, timestamp }   → Plant Detection Service
# agrisense/camera/disease    { imageBase64, timestamp }   → Disease Detection Service
# agrisense/camera/insect     { imageBase64, timestamp }   → Insect Detection Service
# agrisense/actuator/cmd      { actuator, active, mode }   ← Agricultural Practice Service → Pi

# ── Raspberry Pi Connection Notes ────────────────────────────────────────────
# The Pi does NOT connect directly to this web app.
# Data flow:
#   Pi (Python/MQTT) → MQTT Broker (Mosquitto) → Node.js Microservices → PostgreSQL
#                                                                        ↑
#                                          Next.js web app polls REST APIs here
#
# To connect a new Pi, set its broker address in your microservice config.
# To switch from mock to real, set the service URL above and restart.
